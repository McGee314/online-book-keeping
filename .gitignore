# ============================================================
# Personal Online Bookkeeping System — Git Ignore Rules
# ============================================================

# -----------------------------------------------
# Maven / Java — handled by bookkeeping-backend/.gitignore
# (keep only root-level rules here)
# -----------------------------------------------
*.class
*.jar
*.war
*.ear

# Maven wrapper JAR (keep .mvn/wrapper/maven-wrapper.properties!)
bookkeeping-backend/.mvn/wrapper/maven-wrapper.jar

# -----------------------------------------------
# Node / Frontend — handled by bookkeeping-frontend/.gitignore
# (nothing root-specific needed)
# -----------------------------------------------

# -----------------------------------------------
# Docker — local overrides (never commit)
# -----------------------------------------------
docker-compose.override.yml

# Docker volume data (should never end up in repo)
docker/
mysql_data/

# -----------------------------------------------
# Environment / Secrets
# -----------------------------------------------
.env
.env.*
!.env.example
!.env.development
!.env.production
*.env.local
*.env.*.local

# Spring Boot env-specific configs
application-prod.yml
application-local.yml

# -----------------------------------------------
# IDE — IntelliJ IDEA
# -----------------------------------------------
.idea/
*.iws
*.iml
*.ipr
out/

# -----------------------------------------------
# IDE — VS Code
# (keep extensions.json for team consistency)
# -----------------------------------------------
.vscode/settings.json
.vscode/launch.json
.vscode/tasks.json
*.code-workspace

# -----------------------------------------------
# IDE — Eclipse / STS / NetBeans
# -----------------------------------------------
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/

# Maven build output at root level
build/
!**/src/main/**/build/
!**/src/test/**/build/

# -----------------------------------------------
# Editor Swap / Backup Files
# -----------------------------------------------
*.swp
*.swo
*.swn
*~
*.bak
*.orig
\#*#
.\#*

# -----------------------------------------------
# Logs
# -----------------------------------------------
*.log
logs/

# -----------------------------------------------
# -----------------------------------------------
# Let's Encrypt / certbot
# -----------------------------------------------
certbot/

# -----------------------------------------------
# Uploaded files
# -----------------------------------------------
uploads/

# -----------------------------------------------
# Temp / Cache
# -----------------------------------------------
tmp/
temp/
.cache/
.eslintcache
.parcel-cache/
.npm/
*.tmp

# -----------------------------------------------
# Test Coverage
# -----------------------------------------------
coverage/
*.lcov
*.nyc_output

# -----------------------------------------------
# OS Generated Files
# -----------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Desktop.ini
ehthumbs.db
Thumbs.db
$RECYCLE.BIN/

# -----------------------------------------------
# Compiled Python / Script Artifacts
# -----------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python